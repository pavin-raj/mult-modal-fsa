# Multi-Modal Field Service Assistant Configuration

# === Model Provider (Primary: Local Ollama) ===
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
VLM_MODEL=llama3.2-vision:11b
EMBED_MODEL=nomic-embed-text

# === Speech ===
STT_MODEL=base          # tiny, base, small, medium, large-v3 for faster-whisper
TTS_VOICE=en_US-amy-medium   # Piper voice name (if using Piper)

# === RAG / Knowledge ===
CHROMA_PERSIST_DIR=./data/chroma_db
KNOWLEDGE_BASE_DIR=./data/manuals
CASES_FILE=./data/cases/past_cases.json

# === Backend ===
API_HOST=0.0.0.0
API_PORT=8000
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://user:pass@localhost:5432/fsa   # optional, for prod

# === Safety & Agent ===
SAFETY_THRESHOLD=0.75
MAX_AGENT_STEPS=12
ENABLE_HALLUCINATION_CHECK=true

# === Logging / Observability ===
LOG_LEVEL=INFO
LANGFUSE_PUBLIC_KEY=   # optional
LANGFUSE_SECRET_KEY=

# === Feature Flags ===
ENABLE_VISION=true
ENABLE_SPEECH=true
ENABLE_AGENTIC_REASONING=true
OFFLINE_MODE=false
MOCK_MODE=false            # set true for demo without models
